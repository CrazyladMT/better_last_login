# Command feedback
msgid "@1 has never logged in."
msgstr "@1 hat sich noch nie eingeloggt."

msgid "@1 last logged in on @2 (@3)"
msgstr "@1 hat sich zuletzt am @2 eingeloggt (@3)"

# Date formats
# @1: day, @2: Month (name), @3: Year
msgid "@1 @2 @3"
msgstr "@1. @2 @3"

# @1: Month (name), @2: day, @3: Year
msgid "@1 @2, @3"
msgstr "@2. @1 @3"

